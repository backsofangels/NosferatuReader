<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.NosferatuReader" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="readerBackgroundColor">@color/reader_bg_light</item>
        <item name="readerRootBackgroundColor">@color/reader_bg_light</item>
        <item name="readerTextColor">@color/reader_text_light</item>
        <item name="readerProgressBackgroundColor">@color/reader_progress_bg</item>
        <item name="readerAccentColor">@color/primary_color</item>
    </style>

    <style name="Theme.NosferatuReader.Cream">
        <item name="readerBackgroundColor">@color/reader_bg_cream</item>
