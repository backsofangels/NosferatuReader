<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/reader_constraint_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/readerRootBackgroundColor">

    <FrameLayout
        android:id="@+id/reader_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/immersive_header_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingTop="@dimen/spacing_md"
        android:paddingBottom="@dimen/spacing_sm"
        android:paddingHorizontal="@dimen/spacing_16"
        android:gravity="center"
        android:textSize="13sp"
        android:textColor="?attr/readerTextColor"
        android:alpha="0.75"
        android:letterSpacing="0.08"
        android:fontFamily="sans-serif"
        android:maxLines="1"
        android:ellipsize="end"
        tools:text="NOME CAPITOLO"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/immersive_footer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ProgressBar
            android:id="@+id/immersive_progress_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="@dimen/reader_progress_height"
            android:progressTint="?attr/readerTextColor"
            android:progressBackgroundTint="?attr/readerProgressBackgroundColor"
            tools:progress="30"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/immersive_footer_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:paddingTop="@dimen/spacing_sm"
            android:paddingBottom="@dimen/spacing_md"
            android:paddingHorizontal="@dimen/spacing_16"
            android:gravity="center"
            android:textSize="12sp"
            android:textColor="?attr/readerTextColor"
            android:alpha="0.75"
            android:letterSpacing="0.05"
            android:maxLines="1"
            app:layout_constraintTop_toBottomOf="@id/immersive_progress_bar"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/menu_top_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="?attr/readerBackgroundColor"
        android:visibility="gone"
        tools:visibility="visible"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="@dimen/reader_icon_size"
            android:layout_height="@dimen/reader_icon_size"
            android:padding="@dimen/reader_icon_padding"
            android:src="@drawable/ic_expand_less"
            android:rotation="-90"
            android:contentDescription="@string/cd_back"
            app:tint="?attr/readerTextColor"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <ImageView
            android:id="@+id/btn_bookmark_toggle"
            android:layout_width="@dimen/reader_icon_size"
            android:layout_height="@dimen/reader_icon_size"
            android:padding="@dimen/reader_icon_padding"
            android:src="@drawable/ic_bookmark_outline"
            android:contentDescription="@string.cd_bookmark_toggle"
            app:tint="?attr/readerTextColor"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageView
            android:id="@+id/btn_reader_settings"
            android:layout_width="@dimen/reader_icon_size"
            android:layout_height="@dimen/reader_icon_size"
            android:padding="@dimen/reader_icon_padding"
            android:src="@drawable/ic_more"
            android:contentDescription="@string.cd_reader_settings"
            app:tint="?attr/readerTextColor"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btn_bookmark_toggle"
            android:layout_marginEnd="@dimen/spacing_sm" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/readerTextColor"
            android:alpha="0.2"
            app:layout_constraintBottom_toBottomOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/font_controls_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="?attr/readerBackgroundColor"
        android:elevation="4dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/menu_top_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/menu_bottom_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="?attr/readerBackgroundColor"
        android:elevation="8dp"
        android:paddingTop="@dimen/reader_bottom_padding"
        android:paddingBottom="@dimen/reader_bottom_padding"
        android:visibility="gone"
        tools:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/menu_page_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="?attr/readerTextColor"
            android:alpha="0.8"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <SeekBar
            android:id="@+id/menu_seek_bar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/reader_menu_seek_margin_top"
            android:layout_marginHorizontal="@dimen/reader_menu_seek_margin_horizontal"
            android:progressTint="?attr/readerTextColor"
            android:thumbTint="?attr/readerTextColor"
            app:layout_constraintTop_toBottomOf="@id/menu_page_text"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <View
            android:id="@+id/menu_divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:background="?attr/readerTextColor"
            android:alpha="0.2"
            app:layout_constraintTop_toBottomOf="@id/menu_seek_bar" />

        <ImageView
            android:id="@+id/btn_toc"
            android:layout_width="@dimen/reader_icon_size"
            android:layout_height="@dimen/reader_icon_size"
            android:padding="@dimen/reader_icon_padding"
            android:layout_marginTop="@dimen/spacing_sm"
            android:layout_marginStart="@dimen/spacing_sm"
            android:src="@drawable/ic_toc"
            android:contentDescription="@string/cd_open_toc"
            app:tint="?attr/readerTextColor"
            app:layout_constraintTop_toBottomOf="@id/menu_divider"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/menu_book_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textColor="?attr/readerTextColor"
            android:gravity="center"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginHorizontal="@dimen/reader_menu_title_margin_horizontal"
            app:layout_constraintTop_toTopOf="@id/btn_toc"
            app:layout_constraintBottom_toTopOf="@+id/menu_book_author"
            app:layout_constraintStart_toEndOf="@id/btn_toc"
            app:layout_constraintEnd_toStartOf="@+id/btn_bookmarks"
            app:layout_constraintVertical_chainStyle="packed"
            tools:text="TITOLO LIBRO" />

        <TextView
            android:id="@+id/menu_book_author"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="?attr/readerTextColor"
            android:alpha="0.75"
            android:gravity="center"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintTop_toBottomOf="@id/menu_book_title"
            app:layout_constraintBottom_toBottomOf="@id/btn_toc"
            app:layout_constraintStart_toStartOf="@id/menu_book_title"
            app:layout_constraintEnd_toEndOf="@id/menu_book_title"
            tools:text="AUTORE LIBRO" />

        <ImageView
            android:id="@+id/btn_bookmarks"
            android:layout_width="@dimen/reader_icon_size"
            android:layout_height="@dimen/reader_icon_size"
            android:padding="@dimen/reader_icon_padding"
            android:layout_marginTop="@dimen/spacing_sm"
            android:layout_marginEnd="@dimen/spacing_sm"
            android:src="@drawable/ic_books"
            android:contentDescription="@string/bookmarks_title"
            app:tint="?attr/readerTextColor"
            app:layout_constraintTop_toBottomOf="@id/menu_divider"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Font settings button removed (not needed in reader UI) -->

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>